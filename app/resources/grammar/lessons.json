  {
    "id": "future-tense",
    "title": "Future Tense (-ecek / -acak)",
    "description": "Talk about future actions and plans",
    "difficulty": "intermediate",
    "sections": [
      {
        "type": "explanation",
        "content": "The future tense uses -ecek (after front vowels) or -acak (after back vowels), followed by personal suffixes."
      },
      {
        "type": "table",
        "content": "Conjugation of 'gelmek' (to come) - Future Tense",
        "table": {
          "headers": ["Pronoun", "Turkish", "English"],
          "rows": [
            ["Ben", "geleceğim", "I will come"],
            ["Sen", "geleceksin", "You will come"],
            ["O", "gelecek", "He/she will come"],
            ["Biz", "geleceğiz", "We will come"],
            ["Siz", "geleceksiniz", "You (pl) will come"],
            ["Onlar", "gelecekler", "They will come"]
          ]
        }
      },
      {
        "type": "explanation",
        "content": "Note: When followed by a vowel, the 'k' in -ecek/-acak softens to 'ğ'. Example: gelecek → geleceğim (I will come)."
      }
    ],
    "exercises": [
      {
        "type": "conjugation",
        "verb": "gitmek (to go)",
        "tense": "Future Tense",
        "pronouns": ["Ben", "Sen", "O", "Biz", "Siz", "Onlar"],
        "answers": {
          "Ben": "gideceğim",
          "Sen": "gideceksin",
          "O": "gidecek",
          "Biz": "gideceğiz",
          "Siz": "gideceksiniz",
          "Onlar": "gidecekler"
        }
      },
      {
        "type": "fill_blank",
