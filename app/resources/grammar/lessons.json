            ["O", "-(s)i", "evi", "his/her house"],
            ["Biz", "-(i)miz", "evimiz", "our house"],
            ["Siz", "-(i)niz", "eviniz", "your (pl) house"],
            ["Onlar", "-leri", "evleri", "their house"]
