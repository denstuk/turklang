        "hint": "He/she is reading a book"
      },
      {
        "type": "multiple_choice",
        "sentence": "Ben şu an müzik ___ .",
        "options": ["dinliyorum", "dinledin", "dinleyeceğim", "dinlerim"],
        "correctIndex": 0,
        "hint": "Action happening right now — present continuous, 1st person"
      },
      {
